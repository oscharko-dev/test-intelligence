{
  "name": "@oscharko-dev/ti-server",
  "version": "0.1.0-beta.4",
  "description": "HTTP API under /api/v1/: run submission, status, evidence, TMS export, four-eyes approval.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./server-entrypoint": {
      "import": {
        "types": "./dist/server-entrypoint.d.ts",
        "default": "./dist/server-entrypoint.js"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "node -e \"process.exit(0)\"",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@oscharko-dev/ti-contracts": "workspace:*",
    "@oscharko-dev/ti-security": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
