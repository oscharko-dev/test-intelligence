# Test Intelligence — environment-variable reference
#
# Every variable read by the standalone runtime is catalogued here.
# Operators copy this file to `.env`, fill in the required values, and
# load it via their process supervisor. The standalone runtime does NOT
# parse `.env` files itself; the variables must be on the process
# environment when `createTestIntelligenceServer` is called.
#
# Each entry is either:
#   - REQUIRED — the runtime fails closed (503 or hard exit) when missing.
#   - OPTIONAL — a defaulted value documented inline.
#
# Keep this file as the public runtime configuration reference.

# ──────────────────────────────────────────────────────────────────────
# Feature gates
# ──────────────────────────────────────────────────────────────────────

# Master feature gate for the Test Intelligence surface. Truthy values:
# 1, true, yes, on (case-insensitive). When disabled, every write route
# returns 403 FEATURE_GATE_DISABLED.
# OPTIONAL — default: disabled.
TEST_INTELLIGENCE_ENABLED=1

# Nested multi-source ingestion gate (Issue #1431). Strictly nested behind
# TEST_INTELLIGENCE_ENABLED. Truthy values as above.
# OPTIONAL — default: disabled.
TEST_INTELLIGENCE_MULTISOURCE_ENABLED=0

# ──────────────────────────────────────────────────────────────────────
# Transport security
# ──────────────────────────────────────────────────────────────────────

# When set to a truthy value, the server emits a Strict-Transport-Security
# header on every response. Only enable behind a TLS-terminating proxy.
# OPTIONAL — default: disabled (the standalone server is loopback-only).
TEST_INTELLIGENCE_ENABLE_HSTS=0

# ──────────────────────────────────────────────────────────────────────
# LLM gateway
# ──────────────────────────────────────────────────────────────────────
# Runtime env-var names use the Test Intelligence operator namespace.

# REQUIRED for the run/figma-export routes. Operator-controlled gateway
# endpoint. The gateway must expose the API contract expected by the runtime.
TEST_INTELLIGENCE_LLM_GATEWAY_ENDPOINT=

# REQUIRED for the run/figma-export routes when the selected gateway contract
# requires an API-version parameter.
TEST_INTELLIGENCE_LLM_GATEWAY_API_VERSION=

# REQUIRED for the run/figma-export routes. Bearer token used to call the
# upstream model deployment.
TEST_INTELLIGENCE_LLM_GATEWAY_API_KEY=

# Required by Workbench live runs and the production runner.
TEST_INTELLIGENCE_MODEL_ENDPOINT=
TEST_INTELLIGENCE_LLM_API_KEY=

# Optional deployment pins used by the Workbench and production runner.
TEST_INTELLIGENCE_VISUAL_MODEL_ENDPOINT=
TEST_INTELLIGENCE_TESTCASE_MODEL_DEPLOYMENT=
TEST_INTELLIGENCE_VISUAL_PRIMARY_DEPLOYMENT=
TEST_INTELLIGENCE_VISUAL_FALLBACK_DEPLOYMENT=
TEST_INTELLIGENCE_LOGIC_JUDGE_DEPLOYMENT=
TEST_INTELLIGENCE_A11Y_JUDGE_DEPLOYMENT=
TEST_INTELLIGENCE_COVERAGE_PLANNER_DEPLOYMENT=
TEST_INTELLIGENCE_RISK_RANKER_DEPLOYMENT=
TEST_INTELLIGENCE_ICT_REGISTER_REF=

# ──────────────────────────────────────────────────────────────────────
# TMS adapters (per-adapter)
# ──────────────────────────────────────────────────────────────────────
# Each TMS adapter reads its credentials from the
# `TEST_INTELLIGENCE_TMS_<NAME>_*` env-var family. Examples:

# TEST_INTELLIGENCE_TMS_DEMO_BASE_URL=
# TEST_INTELLIGENCE_TMS_DEMO_TOKEN=
# TEST_INTELLIGENCE_TMS_DEMO_BEARER=
# TEST_INTELLIGENCE_TMS_DEMO_OAUTH_ACCESS_TOKEN=
# TEST_INTELLIGENCE_TMS_DEMO_OAUTH_REFRESH_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────

# Minimum log level emitted by `createWorkspaceLogger`. One of:
# debug, info, warn, error.
# OPTIONAL — default: info.
TEST_INTELLIGENCE_LOG_LEVEL=info

# ──────────────────────────────────────────────────────────────────────
# Container entrypoint (Issue #30)
# ──────────────────────────────────────────────────────────────────────
# Read by dist/server-entrypoint.js — the container PID 1. These map
# one-to-one onto CreateTestIntelligenceServerOptions; the standalone
# CLI and library consumers do not read them.

# Bind host inside the container. Default 0.0.0.0 so the host system
# can publish the port via `docker run -p`.
# OPTIONAL — default: 0.0.0.0.
TEST_INTELLIGENCE_HOST=0.0.0.0

# Bind port. Pass 0 for an ephemeral port (used in tests).
# OPTIONAL — default: 1983.
TEST_INTELLIGENCE_PORT=1983

# Per-client rate-limit budget.
# OPTIONAL — default: 60.
TEST_INTELLIGENCE_REQUESTS_PER_MINUTE=60

# Comma-separated CORS allow-list. Empty by default.
# OPTIONAL.
# TEST_INTELLIGENCE_CORS_ORIGINS=https://operator.example,https://console.example

# Operator bearer token. Without it every write route returns
# 503 AUTHENTICATION_UNAVAILABLE. Generate with `openssl rand -hex 32`.
# OPTIONAL but strongly recommended.
# TEST_INTELLIGENCE_BEARER_TOKEN=

# Log format. One of: json, text.
# OPTIONAL — default: json.
TEST_INTELLIGENCE_LOG_FORMAT=json
