{
  "name": "@oscharko-dev/ti-workbench",
  "version": "0.1.0-beta.6",
  "private": true,
  "description": "Test Intelligence operator workbench — Next.js UI for run drafts and model-gateway settings.",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 1983",
    "build": "next build",
    "start": "next start --port 1983",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern next-env.d.ts",
    "test": "vitest run",
    "test:visual": "pnpm run build && playwright test tests/visual/workbench.visual.spec.ts",
    "test:visual:ci": "playwright test tests/visual/workbench.visual.spec.ts",
    "test:visual:update": "pnpm run build && playwright test tests/visual/workbench.visual.spec.ts --update-snapshots",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@oscharko-dev/ti-contracts": "workspace:*",
    "@oscharko-dev/ti-core-engine": "workspace:*",
    "@oscharko-dev/ti-model-gateway": "workspace:*",
    "@oscharko-dev/ti-production-runner": "workspace:*",
    "@oscharko-dev/ti-tenant": "workspace:*",
    "is-path-inside": "workspace:*",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
